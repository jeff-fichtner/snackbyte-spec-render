{
  // Type-checking only — this package ships .mjs source, never compiled output.
  // `tsc` (via the `typecheck` script) checks the JS via allowJs+checkJs and emits
  // nothing.
  //
  // The render logic is extracted verbatim from snackbyte-base (a deliberate
  // faithful copy — see DECISIONS.md), so this is NOT full `strict` mode: forcing
  // JSDoc type annotations onto copied JS would mean rewriting it. Instead we run
  // `checkJs` with the checks that catch *real* defects (undefined variables, bad
  // calls, typos, unreachable code) while tolerating the loose inference of
  // annotation-free JS (empty-array `never[]`, empty-object `{}`, untyped params).
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.mjs"],
  "exclude": ["node_modules", "test", "dist", "coverage"]
}
